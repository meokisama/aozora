{
  "name": "aozora",
  "productName": "Aozora",
  "version": "1.0.0",
  "description": "Desktop EPUB reader for Japanese light novels & manga — tategaki, furigana, fixed-layout two-page spreads, TOC, bookmarks, and full-text search.",
  "main": ".vite/build/main.js",
  "scripts": {
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish",
    "lint": "echo \"No linting configured\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "release:patch": "yarn version --patch --message \"chore(release): bump version to %s\" && git push --follow-tags",
    "release:minor": "yarn version --minor --message \"chore(release): bump version to %s\" && git push --follow-tags",
    "release:major": "yarn version --major --message \"chore(release): bump version to %s\" && git push --follow-tags"
  },
  "keywords": [],
  "author": {
    "name": "Meoki",
    "email": "hi@meoki.vn"
  },
  "homepage": "https://github.com/meokisama/aozora",
  "repository": {
    "type": "git",
    "url": "https://github.com/meokisama/aozora.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@electron-forge/cli": "^7.11.2",
    "@electron-forge/maker-deb": "^7.11.2",
    "@electron-forge/maker-rpm": "^7.11.2",
    "@electron-forge/maker-squirrel": "^7.11.2",
    "@electron-forge/maker-zip": "^7.11.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.2",
    "@electron-forge/plugin-fuses": "^7.11.2",
    "@electron-forge/plugin-vite": "^7.11.2",
    "@electron/fuses": "^1.8.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "42.4.0",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.9"
  },
  "dependencies": {
    "@fontsource/ibm-plex-sans": "^5.2.8",
    "@fontsource/shippori-mincho": "^5.2.8",
    "@radix-ui/react-slot": "^1.3.0",
    "@tailwindcss/vite": "^4.3.1",
    "@zip.js/zip.js": "^2.8.26",
    "better-sqlite3": "^12.11.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "fast-xml-parser": "^5.9.3",
    "lucide-react": "^1.18.0",
    "next-themes": "^0.4.6",
    "path-browserify": "^1.0.1",
    "radix-ui": "^1.6.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "update-electron-app": "^3.2.0",
    "zustand": "^5.0.14"
  },
  "resolutions": {
    "node-abi": "^3.92.0"
  }
}
